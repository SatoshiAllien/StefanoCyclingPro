// Copy to Development.xcconfig (or edit Development.xcconfig directly).
// Required for device install — empty DEVELOPMENT_TEAM causes signing + CoreDeviceError 3002.
//
// Personal Team example: Xcode → Settings → Accounts → Steven Cianci (Personal Team)
// Team ID: https://developer.apple.com/account → Membership (10-character string)
//
DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE
CODE_SIGN_STYLE = Automatic